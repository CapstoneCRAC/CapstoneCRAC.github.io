---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/content";

export async function getStaticPaths() {
  const projects = await getCollection("projects", (project) => project.data.detailLevel === "full");

  return projects.map((project) => ({
    params: { projectId: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  reportTitle,
  author,
  year,
  summary,
  cover,
  video,
  gallery,
  publicLinks,
} = project.data;

const heroImage = !video ? (cover ?? gallery[0]) : null;
const galleryItems = heroImage && !cover ? gallery.slice(1) : gallery;
const hasHeroMedia = Boolean(video || heroImage);
const hasGallery = galleryItems.length > 0;

function displayYear(value: string) {
  return value.replace("-", "–");
}
---

<BaseLayout title={`${reportTitle ?? title} | Projects`} description={summary}>
  <main>
    <section class:list={["detail-hero", { "detail-hero--with-media": hasHeroMedia }] }>
      <div class="wrap">
        <a class="back-link" href={withBase("/projects/")}>← All projects</a>

        <div class:list={["detail-hero__grid", { "detail-hero__grid--text": !hasHeroMedia }] }>
          <div class="detail-hero__copy">
            <p class="detail-overline">Student project · {displayYear(year)}</p>
            <h1 class="detail-title">{reportTitle ?? title}</h1>
            {reportTitle && <p class="detail-source-title">Published listing: {title}</p>}
            <p class="detail-summary">{summary}</p>
            <p class="detail-byline">By <strong>{author}</strong></p>
            {
              publicLinks.length > 0 && (
                <div class="detail-actions" aria-label="Public project links">
                  {publicLinks.map((link) => (
                    <a
                      class:list={["project-public-link", `project-public-link--${link.kind}`]}
                      href={link.url}
                      target="_blank"
                      rel="noreferrer"
                    >
                      {link.label} <span aria-hidden="true">↗</span>
                    </a>
                  ))}
                </div>
              )
            }
          </div>

          {
            video && (
              <figure class="detail-feature detail-feature--video">
                <div class="detail-feature__media video-frame">
                  <video controls preload="metadata" aria-label={`${reportTitle ?? title} demo video`}>
                    <source src={withBase(video.src)} type={video.type} />
                    Video playback is unavailable in this browser.
                  </video>
                </div>
                <figcaption>{video.caption ?? "Project demo"}{video.duration && ` · ${video.duration}`}</figcaption>
              </figure>
            )
          }

          {
            heroImage && (
              <figure class="detail-feature detail-feature--image">
                <div class="detail-feature__media">
                  <img src={withBase(heroImage.src)} alt={heroImage.alt} loading="eager" />
                </div>
                {"caption" in heroImage && heroImage.caption && <figcaption>{heroImage.caption}</figcaption>}
              </figure>
            )
          }
        </div>
      </div>
    </section>

    <div class:list={["wrap", "detail-body", { "detail-body--with-gallery": hasGallery }] }>
      <article class="detail-main story">
        <div class="story-marker" aria-hidden="true">Project story</div>
        <div class="project-story">
          <Content />
        </div>
      </article>

      {
        hasGallery && (
          <aside class="detail-gallery" aria-label="Project gallery">
            <div class="detail-gallery__label">Selected screens</div>
            <div class="gallery-list">
              {galleryItems.map((item) => (
                <a class="gallery-thumb" href={withBase(item.src)} target="_blank" rel="noreferrer">
                  <div class="gallery-thumb__image">
                    <img src={withBase(item.src)} alt={item.alt} loading="lazy" />
                  </div>
                  <p class="gallery-thumb__caption">{item.caption ?? item.title}</p>
                </a>
              ))}
            </div>
          </aside>
        )
      }
    </div>
  </main>
</BaseLayout>
