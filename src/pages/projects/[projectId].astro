---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/content";

export async function getStaticPaths() {
  const projects = await getCollection("projects", (project) => project.data.detailLevel === "full");

  return projects.map((project) => ({
    params: { projectId: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  author,
  year,
  summary,
  video,
  gallery,
} = project.data;
const closingFigure = gallery.length > 0 ? gallery[gallery.length - 1] : null;

function displayYear(value: string) {
  return value.replace("-", "–");
}
---

<BaseLayout title={`${title} | Projects`} description={summary}>
  <main>
    <section class="detail-head detail-head--plain">
      <div class="wrap">
        <a class="back-link" href={withBase("/projects/")}>← Back to projects</a>
        <h1 class="detail-title">{title}</h1>
      </div>
    </section>

    <div class="wrap detail-grid">
      <article class="detail-main story">
        <div class="project-story">
          <Content />
        </div>

        {
          closingFigure && (
            <figure class="closing-figure">
              <div class="closing-figure__image">
                <img src={withBase(closingFigure.src)} alt={closingFigure.alt} loading="lazy" />
              </div>
              <figcaption class="figcaption">
                {closingFigure.caption ?? closingFigure.title}
              </figcaption>
            </figure>
          )
        }
      </article>

      <aside class="detail-aside" aria-label="Project details">
        <section class="panel panel--meta" aria-labelledby="project-info-heading">
          <div class="panel-label" id="project-info-heading">Project info</div>
          <dl class="meta-list">
            <div class="meta-item">
              <dt>Author</dt>
              <dd>{author}</dd>
            </div>
            <div class="meta-item">
              <dt>Year</dt>
              <dd>{displayYear(year)}</dd>
            </div>
          </dl>
        </section>

        {
          video && (
            <section class="panel video-panel" aria-labelledby="video-heading">
              <div class="panel-label" id="video-heading">Video</div>
              <div class="video-frame">
                <video controls preload="metadata" aria-label={`${title} demo video`}>
                  <source src={withBase(video.src)} type={video.type} />
                  Video playback is unavailable in this browser.
                </video>
              </div>
              <p class="video-meta">
                {video.caption ?? "Demo walkthrough"}
                {video.duration && ` · ${video.duration}`}
              </p>
            </section>
          )
        }

        {
          gallery.length > 0 && (
            <section class="panel" aria-labelledby="gallery-heading">
              <div class="panel-label" id="gallery-heading">Gallery</div>
              <div class="gallery-list">
                {gallery.map((item) => (
                  <a class="gallery-thumb" href={withBase(item.src)} target="_blank" rel="noreferrer">
                    <div class="gallery-thumb__image">
                      <img src={withBase(item.src)} alt={item.alt} loading="lazy" />
                    </div>
                    <p class="gallery-thumb__caption">{item.caption ?? item.title}</p>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </aside>
    </div>
  </main>
</BaseLayout>
