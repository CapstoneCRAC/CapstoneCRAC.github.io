---
import { getCollection } from "astro:content";
import ProjectVisual from "../components/ProjectVisual.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/content";

const recentProjects = (await getCollection("projects"))
  .filter((project) => project.data.cohortId === "coh3")
  .sort((a, b) => {
    const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
    const orderB = b.data.order ?? Number.POSITIVE_INFINITY;
    if (orderA !== orderB) return orderA - orderB;
    return a.id.localeCompare(b.id);
  })
  .slice(0, 3);

function displayYear(year: string) {
  return year.replaceAll("-", "–");
}
---

<BaseLayout title="Capstone Project Platform">
  <main>
    <section class="wrap hero hero--center">
      <h1 class="hero-title">
        Capstone project work,<br />made to be read.
      </h1>
      <p class="hero-sub">
        A quiet public archive for capstone project work — the ideas behind them, the media around them, and the authors who made them.
      </p>
    </section>

    <section class="wrap featured" aria-labelledby="recent-projects-heading">
      <div class="section-head">
        <h2 id="recent-projects-heading">Recent projects</h2>
        <a class="link-arrow" href={withBase("/projects/")}>
          View all <span class="link-arrow__icon" aria-hidden="true">→</span>
        </a>
      </div>

      {
        recentProjects.length > 0 ? (
          <div class="project-card-grid">
            {recentProjects.map((project, index) => (
              <article class="project-card">
                <a class="project-card__detail" href={withBase(`/projects/#${project.id}`)}>
                  <div class="project-card__image">
                    {
                      project.data.cover ? (
                        <img src={withBase(project.data.cover.src)} alt={project.data.cover.alt} loading="lazy" />
                      ) : (
                        <ProjectVisual order={project.data.order ?? index + 1} compact />
                      )
                    }
                  </div>
                  <div class="project-card__body">
                    {project.data.publicLinks.length > 0 && <span class="public-chip">↗ Public project</span>}
                    <h3 class="project-card__title">{project.data.title}</h3>
                    <p class="project-card__author">{project.data.author} · {displayYear(project.data.year)}</p>
                  </div>
                </a>
                {
                  project.data.publicLinks[0] && (
                    <a class="project-card__public" href={project.data.publicLinks[0].url} target="_blank" rel="noreferrer">
                      {project.data.publicLinks[0].label} <span aria-hidden="true">↗</span>
                    </a>
                  )
                }
              </article>
            ))}
          </div>
        ) : (
          <p class="empty-state">No projects have been added yet.</p>
        )
      }
    </section>
  </main>
</BaseLayout>
