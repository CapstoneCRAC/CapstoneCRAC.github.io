---
import { getCollection } from "astro:content";
import ProjectVisual from "../components/ProjectVisual.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/content";

type SectionStatus = "Current" | "Upcoming" | "Past";

const cohorts = (await getCollection("cohorts"))
  .filter((cohort) => cohort.data.publiclyVisible)
  .sort((a, b) => a.data.order - b.data.order);

const projects = await getCollection("projects");

function compareProjects(
  a: (typeof projects)[number],
  b: (typeof projects)[number]
) {
  const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
  const orderB = b.data.order ?? Number.POSITIVE_INFINITY;
  if (orderA !== orderB) return orderA - orderB;
  return a.id.localeCompare(b.id);
}

const visibleSections = cohorts
  .map((cohort) => {
    const cohortProjects = projects
      .filter((project) => project.data.cohortId === cohort.data.cohortId)
      .sort(compareProjects);

    return {
      cohort,
      projects: cohortProjects
    };
  })
  .filter((section) => section.projects.length > 0);

function displayYear(year: string) {
  return year.replaceAll("-", "–");
}

function projectCountLabel(count: number | null, fallback: number) {
  const total = count ?? fallback;
  return `${total} ${total === 1 ? "project" : "projects"}`;
}

function statusClass(status: SectionStatus) {
  if (status === "Current") return "status-chip--current";
  if (status === "Upcoming") return "status-chip--upcoming";
  return "status-chip--past";
}
---

<BaseLayout title="Projects | Capstone Platform">
  <main>
    <section class="wrap page-head page-head--plain">
      <h1 class="page-title">Capstone projects</h1>
    </section>

    <section class="wrap project-groups" aria-label="Capstone project cohorts">
      {
        visibleSections.map((section) => (
          <section
            class:list={[
              "cohort-section",
              section.cohort.data.displayMode === "preview" ? "cohort-section--preview" : ""
            ]}
            aria-labelledby={`${section.cohort.data.cohortId}-heading`}
          >
            <header class="cohort-section__head">
              <div class="cohort-section__identity">
                <h2 id={`${section.cohort.data.cohortId}-heading`} class="cohort-section__year">
                  {displayYear(section.cohort.data.year)}
                </h2>
                <span class:list={["status-chip", statusClass(section.cohort.data.status)]}>
                  {section.cohort.data.status}
                </span>
              </div>
              <p class="cohort-section__count">
                {projectCountLabel(section.cohort.data.count, section.projects.length)}
              </p>
            </header>

            {
              section.cohort.data.displayMode === "full" ? (
                <div class="current-project-grid">
                  {section.projects.map((project, index) => (
                    <a class="full-project-card" id={project.id} href={withBase(`/projects/${project.id}/`)}>
                      <div class="full-project-card__media">
                        {
                          project.data.cover ? (
                            <img src={withBase(project.data.cover.src)} alt={project.data.cover.alt} loading="lazy" />
                          ) : (
                            <ProjectVisual order={project.data.order ?? index + 1} />
                          )
                        }
                      </div>
                      <div class="full-project-card__body">
                        <div class="full-project-card__top">
                          {project.data.hasVideo && <span class="video-chip">▸ Video</span>}
                        </div>
                        <h3 class="full-project-card__title">{project.data.title}</h3>
                        <p class="full-project-card__author">{project.data.author}</p>
                        <p class="full-project-card__desc">{project.data.summary}</p>
                      </div>
                    </a>
                  ))}
                </div>
              ) : (
                <div class="upcoming-panel">
                  <div class="upcoming-grid">
                    {section.projects.map((project, index) => (
                      <article class="upcoming-card" id={project.id}>
                        <div class="upcoming-card__media">
                          {
                            project.data.cover ? (
                              <img src={withBase(project.data.cover.src)} alt={project.data.cover.alt} loading="lazy" />
                            ) : (
                              <ProjectVisual order={project.data.order ?? index + 1} compact />
                            )
                          }
                        </div>
                        <div class="upcoming-card__body">
                          <h3 class="upcoming-card__title">{project.data.title}</h3>
                          <p class="upcoming-card__author">{project.data.author}</p>
                          <p class="upcoming-card__desc">{project.data.summary}</p>
                        </div>
                      </article>
                    ))}
                  </div>
                </div>
              )
            }
          </section>
        ))
      }
    </section>
  </main>
</BaseLayout>
