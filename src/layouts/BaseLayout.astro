---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Capstone project showcase platform for student work on emerging technologies in teaching and work contexts."
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const navItems = [
  { href: "/", label: "Home" },
  { href: "/examples/", label: "Examples" },
  { href: "/about/", label: "About Us" }
];

function isActive(href: string) {
  if (href === "/") return Astro.url.pathname === "/";
  return Astro.url.pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}favicon/apple-touch-icon.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon/favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon/favicon-16x16.png`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}favicon/site.webmanifest`} />
    <link rel="shortcut icon" href={`${import.meta.env.BASE_URL}favicon/favicon.ico`} />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
  </head>
  <body class="bg-[#f6f8f3] text-[#14231b] antialiased">
    <header class="border-b border-[#d8e1d3] bg-white/95">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-5 py-5 md:flex-row md:items-center md:justify-between md:px-8">
        <a class="flex items-center gap-3 text-lg font-semibold tracking-normal text-[#143b2b]" href={`${import.meta.env.BASE_URL}`}>
          <img
            class="h-9 w-auto"
            src={`${import.meta.env.BASE_URL}eduhk-logo.png`}
            alt="The Education University of Hong Kong"
          />
          <span class="border-l border-[#d8e1d3] pl-3">Capstone Platform</span>
        </a>
        <nav class="flex flex-wrap gap-1 text-sm" aria-label="Primary navigation">
          {
            navItems.map((item) => (
              <a
                class:list={[
                  "rounded-md px-3 py-2 font-semibold transition-colors",
                  isActive(item.href)
                    ? "bg-[#dcefe7] text-[#123d2d]"
                    : "text-[#405249] hover:bg-[#f0f5ed] hover:text-[#143b2b]"
                ]}
                href={`${import.meta.env.BASE_URL}${item.href.replace(/^\//, "")}`}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <slot />
    <footer class="border-t border-[#d8e1d3] bg-white">
      <div class="mx-auto max-w-7xl px-5 py-6 text-sm leading-6 text-[#627067] md:px-8">
        First-version framework for the EdUHK capstone project platform.
      </div>
    </footer>
  </body>
</html>
